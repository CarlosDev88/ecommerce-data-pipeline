{
  "event_name": "view_item",
  "description": "Usuario hace clic en un producto específico para ver detalle. Disparador obligatorio antes de add_to_cart.",
  "fields": {
    "id_sesion": {"type": "string"},
    "id_usuario": {"type": "string", "nullable": true},
    "timestamp": {"type": "string", "format": "iso8601"},
    "id_producto": {"type": "string", "description": "product_id real de VTEX"},
    "nombre_producto": {"type": "string"},
    "precio_actual": {"type": "number"},
    "categoria": {"type": "string"},
    "subcategoria": {"type": "string", "nullable": true},
    "brand": {"type": "string", "nullable": true}
  }
}
